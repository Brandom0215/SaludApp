<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EDF1F6"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp">

            <ImageView
                android:id="@+id/btnRegresar"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_flecha_regresar"
                android:paddingEnd="8dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Nuevo Medicamento"
                android:textColor="#1A4375"
                android:textSize="22sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginEnd="32dp" />
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nombre del Medicamento"
                    android:textColor="#1A4375"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <!-- Use EditText with custom drawable or simple background -->
                <EditText
                    android:id="@+id/etNombreMed"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/imput_round"
                    android:hint="Ej: Paracetamol 500mg"
                    android:paddingHorizontal="16dp"
                    android:inputType="textCapWords"
                    android:layout_marginBottom="24dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hora de la toma"
                    android:textColor="#1A4375"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <TimePicker
                    android:id="@+id/timePickerHora"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:timePickerMode="spinner"
                    android:layout_marginBottom="24dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cantidad de Pastillas"
                    android:textColor="#1A4375"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <NumberPicker
                    android:id="@+id/numberPickerDosis"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginBottom="32dp"/>

                <Button
                    android:id="@+id/btnGuardarMedicamento"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:backgroundTint="#1A4375"
                    android:text="Guardar"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    app:cornerRadius="16dp" />
            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</LinearLayout>
