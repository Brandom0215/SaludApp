<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EDF1F6"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp">
            
            <ImageView
                android:id="@+id/btnRegresar"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_flecha_regresar"
                android:paddingEnd="8dp" />
                
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Control de Hidratación"
                android:textColor="#1A4375"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginEnd="32dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvConsumoVasos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hoy has bebido: 0 Vasos"
            android:textColor="#5E7A9D"
            android:textSize="18sp"
            android:layout_marginBottom="32dp" />

        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="32dp"
            android:background="#FFFFFF"
            android:padding="16dp">

            <ImageView
                android:layout_width="160dp"
                android:layout_height="320dp"
                android:src="@drawable/silueta"
                app:tint="#E0E0E0" />

            <ImageView
                android:id="@+id/ivCuerpoLleno"
                android:layout_width="160dp"
                android:layout_height="320dp"
                android:src="@drawable/relleno_agua"
                app:tint="#00A8FF" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/btn1Vaso"
                android:layout_width="140dp"
                android:layout_height="55dp"
                android:layout_marginEnd="8dp"
                android:backgroundTint="#1A4375"
                android:text="+ 1 Vaso"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="16dp" />

            <Button
                android:id="@+id/btn2Vasos"
                android:layout_width="140dp"
                android:layout_height="55dp"
                android:layout_marginStart="8dp"
                android:backgroundTint="#1A4375"
                android:text="+ 2 Vasos"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="16dp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnVerHistorial"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginBottom="32dp"
            android:backgroundTint="#1A4375"
            android:text="Ver historial de consumo"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            app:cornerRadius="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Configurar Recordatorios"
                android:textColor="#1A4375"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:background="#FFFFFF"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Notificaciones de Hidratación"
                        android:textColor="#5E7A9D"
                        android:textSize="16sp" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchNotificaciones"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

    </LinearLayout>
</ScrollView>