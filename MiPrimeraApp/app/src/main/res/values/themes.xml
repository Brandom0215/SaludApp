<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.MiPrimeraApp" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">#1A4375</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">#D4E3FF</item>
        <item name="colorOnPrimaryContainer">#001C3A</item>
        <item name="colorSecondary">#2A5A8F</item>
        <item name="colorOnSecondary">@color/white</item>
        
        <!-- Fondo de la aplicación general -->
        <item name="android:windowBackground">@color/blue_bg</item>
    </style>

    <style name="Theme.MiPrimeraApp" parent="Base.Theme.MiPrimeraApp" />

    <!-- ESTILO BASE DE LAS CARDS -->
    <style name="SaludCardStyle" parent="Widget.Material3.CardView.Elevated">
        <item name="android:layout_margin">8dp</item>
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/white</item>
    </style>

    <style name="SaludCardContentStyle">
        <item name="android:padding">8dp</item>
        <item name="android:gravity">center</item>
        <item name="android:maxLines">2</item>
        <item name="android:ellipsize">end</item>
    </style>

    <!-- Estilos de Texto -->
    <style name="TitleTextStyle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:textColor">#1A4375</item> <!-- Dark blue -->
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
        <item name="android:maxLines">2</item>
        <item name="android:ellipsize">end</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="SubtitleTextStyle" parent="TextAppearance.Material3.BodySmall">
        <item name="android:layout_marginTop">4dp</item>
        <item name="android:textColor">#5E7A9D</item> <!-- Grey/blue -->
        <item name="android:gravity">center</item>
        <item name="android:maxLines">2</item>
        <item name="android:ellipsize">end</item>
        <item name="android:fontFamily">sans-serif-light</item>
    </style>

    <!-- Inputs de Cristal -->
    <style name="GlassInputStyle" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/white</item>
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
    </style>

    <style name="GlassButtonStyle" parent="Widget.Material3.Button">
        <item name="cornerRadius">24dp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:padding">12dp</item>
    </style>

    <style name="CircleImageView">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="CustomAlertDialogTheme" parent="Theme.AppCompat.Light.Dialog.Alert">
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>
</resources>
